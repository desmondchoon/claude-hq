{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude HQ",
  "version": "0.1.0",
  "identifier": "io.boleh.claude-hq",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude HQ",
        "width": 640,
        "height": 480,
        "minWidth": 280,
        "minHeight": 220,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": true,
        "transparent": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
